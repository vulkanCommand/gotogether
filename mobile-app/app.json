{
  "expo": {
    "name": "GoTogether",
    "slug": "gotogether",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/prototype/onboarding-illustration.png",
      "resizeMode": "contain",
      "backgroundColor": "#4368E8"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gdkalyan.gotogether",
      "buildNumber": "12",
      "icon": "./assets/icon.png",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSContactsUsageDescription": "GoTogether uses your contacts only when you choose to find friends already using the app.",
        "NSLocationWhenInUseUsageDescription": "GoTogether uses your location only when you choose to share your live position with your trip group.",
        "NSPhotoLibraryUsageDescription": "GoTogether uses your photos only when you choose to upload a profile picture or trip memory.",
        "NSPhotoLibraryAddUsageDescription": "GoTogether saves trip memories you choose to upload."
      }
    },
    "android": {
      "package": "com.gotogether.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4368E8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "READ_CONTACTS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "defaultChannel": "default",
          "color": "#4368E8",
          "icon": "./assets/notification-icon.png"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "./plugins/with-rnfb-fix",
      "expo-font",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "76d16f4f-729c-4390-9d90-746501113488"
      }
    },
    "owner": "vulkancommander"
  }
}
